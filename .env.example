# WattTime API credentials
WATTTIME_USER=your_watttime_username
WATTTIME_PASS=your_watttime_password

# PostgreSQL credentials (used by docker-compose for the local DB)
POSTGRES_USER=ghguser
POSTGRES_PASSWORD=ghgpassword
POSTGRES_DB=ghgdb

# Full connection URL (overrides individual vars above for the app)
# For local Docker: set automatically by docker-compose
# For cloud: set to your managed DB URL (e.g. from Railway, Supabase, AWS RDS)
DATABASE_URL=postgresql://ghguser:ghgpassword@localhost:5432/ghgdb
